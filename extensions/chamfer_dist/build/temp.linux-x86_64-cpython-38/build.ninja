ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.0/bin/nvcc

cflags = -pthread -B /home/tejas/miniconda3/envs/newp2c/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include/TH -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-12.0/include -I/home/tejas/miniconda3/envs/newp2c/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1017"' -DTORCH_EXTENSION_NAME=chamfer -D_GLIBCXX_USE_CXX11_ABI=1 -std=c++17
cuda_cflags = -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include/TH -I/home/tejas/miniconda3/envs/newp2c/lib/python3.8/site-packages/torch/include/THC -I/usr/local/cuda-12.0/include -I/home/tejas/miniconda3/envs/newp2c/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1017"' -DTORCH_EXTENSION_NAME=chamfer -D_GLIBCXX_USE_CXX11_ABI=1 -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/tejas/Downloads/Partial2Complete-main/extensions/chamfer_dist/build/temp.linux-x86_64-cpython-38/chamfer.o: cuda_compile /home/tejas/Downloads/Partial2Complete-main/extensions/chamfer_dist/chamfer.cu
build /home/tejas/Downloads/Partial2Complete-main/extensions/chamfer_dist/build/temp.linux-x86_64-cpython-38/chamfer_cuda.o: compile /home/tejas/Downloads/Partial2Complete-main/extensions/chamfer_dist/chamfer_cuda.cpp






